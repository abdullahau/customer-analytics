# .claudeignore — keep large, generated, or binary/reference files out of Claude's
# context so search and reads stay fast and relevant. Source .qmd / .py and the
# actively-developed notebooks are intentionally NOT ignored.

# --- Environment & lock ---
.venv/
uv.lock

# --- Generated / rendered output (regenerated by Quarto) ---
docs/
.quarto/
*_files/
/*.html

# --- Compiled Stan artifacts ---
*.so
*.o

# --- Binary documents & assets (reference material, not editable source) ---
*.pdf
*.xlsx
*.xls
*.pptx
*.docx
*.gif
*.png
*.jpg
*.jpeg
*.webp

# --- Quarto scratch / freeze ---
.quarto/

# --- Heavy reference / vendored material ---
Projects/
references/
excel-models/
stan/implementations/

# --- Notebook checkpoints & caches ---
.ipynb_checkpoints/
__pycache__/
*.py[cod]

# --- OS noise ---
*.DS_Store
